<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_screen_green">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- HEADER -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="190dp"
            android:orientation="vertical"
            android:background="@drawable/bg_green_header"
            android:padding="24dp">

            <TextView
                android:id="@+id/btnBack"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="&lt;"
                android:textColor="@color/white"
                android:textSize="30sp"
                android:textStyle="bold"
                android:padding="4dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Prayer Times"
                android:textColor="@color/white"
                android:textStyle="bold"
                android:textSize="28sp"
                android:layout_marginTop="24dp" />

            <TextView
                android:id="@+id/textPrayerLocation"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Getting location..."
                android:textColor="@color/white"
                android:textSize="14sp"
                android:layout_marginTop="8dp" />

        </LinearLayout>

        <!-- BODY -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp"
            android:layout_marginTop="-40dp">

            <!-- NEXT PRAYER CARD -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_white_card"
                android:padding="18dp">

                <TextView
                    android:id="@+id/textNextPrayer"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Loading..."
                    android:textColor="@color/text_dark"
                    android:textStyle="bold"
                    android:textSize="20sp" />

                <TextView
                    android:id="@+id/textNextPrayerTime"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="--:--"
                    android:textColor="@color/primary_green"
                    android:textStyle="bold"
                    android:textSize="30sp"
                    android:layout_marginTop="8dp" />

                <TextView
                    android:id="@+id/textReminderStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Fetching prayer times..."
                    android:textColor="@color/text_gray"
                    android:textSize="13sp"
                    android:layout_marginTop="6dp" />

            </LinearLayout>

            <!-- SECTION TITLE -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Today's Prayer Schedule"
                android:textColor="@color/text_dark"
                android:textStyle="bold"
                android:textSize="18sp"
                android:layout_marginTop="18dp"
                android:layout_marginBottom="8dp" />

            <!-- Fajr -->
            <TextView
                android:id="@+id/tvSubuh"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Fajr           --:--"
                android:textColor="@color/text_dark"
                android:textSize="16sp"
                android:background="@drawable/bg_white_card"
                android:padding="16dp"
                android:layout_marginTop="8dp" />

            <!-- Dhuhr -->
            <TextView
                android:id="@+id/tvZohor"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Dhuhr          --:--"
                android:textColor="@color/text_dark"
                android:textSize="16sp"
                android:background="@drawable/bg_white_card"
                android:padding="16dp"
                android:layout_marginTop="8dp" />

            <!-- Asr -->
            <TextView
                android:id="@+id/tvAsar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Asr            --:--"
                android:textColor="@color/text_dark"
                android:textSize="16sp"
                android:background="@drawable/bg_white_card"
                android:padding="16dp"
                android:layout_marginTop="8dp" />

            <!-- Maghrib -->
            <TextView
                android:id="@+id/tvMaghrib"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Maghrib        --:--"
                android:textColor="@color/text_dark"
                android:textSize="16sp"
                android:background="@drawable/bg_white_card"
                android:padding="16dp"
                android:layout_marginTop="8dp" />

            <!-- Isha -->
            <TextView
                android:id="@+id/tvIsyak"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Isha           --:--"
                android:textColor="@color/text_dark"
                android:textSize="16sp"
                android:background="@drawable/bg_white_card"
                android:padding="16dp"
                android:layout_marginTop="8dp" />

        </LinearLayout>

    </LinearLayout>
</ScrollView>