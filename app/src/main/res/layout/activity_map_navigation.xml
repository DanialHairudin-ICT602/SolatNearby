<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/mapRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <fragment
        android:id="@+id/mapFragment"
        android:name="com.google.android.gms.maps.MapFragment"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <TextView
        android:id="@+id/btnBack"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginStart="18dp"
        android:layout_marginTop="18dp"
        android:gravity="center"
        android:text="&lt;"
        android:textColor="@color/primary_green"
        android:textSize="30sp"
        android:textStyle="bold"
        android:background="@drawable/bg_white_card" />

    <LinearLayout
        android:id="@+id/topDestinationCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bg_white_card"
        android:padding="16dp"
        android:layout_marginStart="18dp"
        android:layout_marginEnd="18dp"
        android:layout_marginTop="78dp">

        <TextView
            android:id="@+id/textDestinationName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Detecting nearest masjid..."
            android:textColor="@color/text_dark"
            android:textStyle="bold"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/textRouteInfo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Waiting for GPS location..."
            android:textColor="@color/text_gray"
            android:textSize="13sp"
            android:layout_marginTop="5dp" />

        <LinearLayout
            android:id="@+id/searchMapRow"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="10dp">

            <EditText
                android:id="@+id/editMapSearch"
                android:layout_width="0dp"
                android:layout_height="46dp"
                android:layout_weight="1"
                android:hint="Search masjid"
                android:singleLine="true"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:textColor="@color/text_dark"
                android:textColorHint="@color/text_gray"
                android:background="@drawable/bg_outline_green_button" />

            <Button
                android:id="@+id/btnMapSearch"
                android:layout_width="88dp"
                android:layout_height="46dp"
                android:layout_marginStart="8dp"
                android:text="Go"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:textStyle="bold"
                android:background="@drawable/bg_green_button"
                android:backgroundTint="@null" />

        </LinearLayout>

    </LinearLayout>

    <LinearLayout
        android:id="@+id/bottomNavigationCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="vertical"
        android:background="@drawable/bg_white_card"
        android:padding="20dp"
        android:layout_margin="18dp">

        <TextView
            android:id="@+id/textNavigationInstruction"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Route guide will appear here"
            android:textColor="@color/text_dark"
            android:textStyle="bold"
            android:textSize="18sp" />

        <TextView
            android:id="@+id/textArrivalStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Waiting for navigation status"
            android:textColor="@color/text_gray"
            android:textSize="13sp"
            android:layout_marginTop="6dp" />

        <Button
            android:id="@+id/btnStartNavigation"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:text="Start Navigation"
            android:textAllCaps="false"
            android:textColor="@color/white"
            android:textStyle="bold"
            android:background="@drawable/bg_green_button"
            android:backgroundTint="@null"
            android:layout_marginTop="14dp" />

        <Button
            android:id="@+id/btnStopNavigation"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:text="Stop Navigation"
            android:textAllCaps="false"
            android:textColor="@color/primary_green"
            android:textStyle="bold"
            android:background="@drawable/bg_outline_green_button"
            android:backgroundTint="@null"
            android:layout_marginTop="10dp"
            android:visibility="gone" />

    </LinearLayout>

</FrameLayout>