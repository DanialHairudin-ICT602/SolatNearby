<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/bg_screen_green">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="160dp"
        android:orientation="vertical"
        android:background="@drawable/bg_green_header"
        android:padding="24dp">

        <TextView
            android:id="@+id/btnBack"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="←"
            android:textColor="@color/white"
            android:textSize="30sp"
            android:textStyle="bold"
            android:padding="4dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📋 History"
            android:textColor="@color/white"
            android:textStyle="bold"
            android:textSize="28sp"
            android:layout_marginTop="8dp" />



    </LinearLayout>

    <!-- Tabs -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:layout_marginTop="-10dp">

        <Button
            android:id="@+id/btnTabAll"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="📋 All History"
            android:textAllCaps="false"
            android:textSize="14sp"
            android:textStyle="bold"
            android:background="@drawable/bg_green_button"
            android:textColor="@color/white"
            android:layout_marginEnd="6dp" />

        <Button
            android:id="@+id/btnTabFavorites"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="❤️ Favorites"
            android:textAllCaps="false"
            android:textSize="14sp"
            android:textStyle="bold"
            android:background="@drawable/bg_outline_green_button"
            android:textColor="@color/primary_green"
            android:layout_marginStart="6dp" />

    </LinearLayout>

    <!-- Empty State Text -->
    <TextView
        android:id="@+id/textEmptyState"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="No history yet.\nNavigate to a masjid to save."
        android:textColor="@color/text_gray"
        android:textSize="16sp"
        android:gravity="center"
        android:padding="40dp"
        android:visibility="gone" />

    <!-- List View -->
    <ListView
        android:id="@+id/listHistory"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="14dp"
        android:divider="@android:color/transparent"
        android:dividerHeight="12dp" />

</LinearLayout>