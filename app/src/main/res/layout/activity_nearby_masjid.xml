<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/bg_screen_green">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="170dp"
        android:orientation="vertical"
        android:background="@drawable/bg_green_header"
        android:padding="24dp">

        <TextView
            android:id="@+id/btnBack"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="&lt;"
            android:textColor="@color/white"
            android:textSize="30sp"
            android:textStyle="bold"
            android:padding="4dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Nearby Masjid"
            android:textColor="@color/white"
            android:textStyle="bold"
            android:textSize="28sp"
            android:layout_marginTop="8dp" />

        <TextView
            android:id="@+id/textNearbySubtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Showing masjid and surau near your location"
            android:textColor="@color/white"
            android:textSize="14sp"
            android:layout_marginTop="6dp" />

    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@drawable/bg_white_card"
        android:padding="10dp"
        android:layout_marginStart="14dp"
        android:layout_marginEnd="14dp"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="4dp">

        <EditText
            android:id="@+id/editSearchMasjid"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:hint="Search masjid or surau"
            android:singleLine="true"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:textColor="@color/text_dark"
            android:textColorHint="@color/text_gray"
            android:background="@android:color/transparent" />

        <Button
            android:id="@+id/btnSearchMasjid"
            android:layout_width="90dp"
            android:layout_height="48dp"
            android:text="Search"
            android:textAllCaps="false"
            android:textColor="@color/white"
            android:textStyle="bold"
            android:background="@drawable/bg_green_button"
            android:backgroundTint="@null" />

    </LinearLayout>

    <ListView
        android:id="@+id/listMasjid"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="14dp"
        android:divider="@android:color/transparent"
        android:dividerHeight="12dp" />

</LinearLayout>